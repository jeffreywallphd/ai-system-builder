{
  "schemaVersion": "1.0.0",
  "artifactType": "context-pack-catalog",
  "description": "Contract for indexing context packs used by AI and human routing workflows.",
  "contextAssetMetadataContractPath": "docs/context/context-asset-metadata.contract.json",
  "entryRequiredFields": [
    "id",
    "title",
    "purpose",
    "domain",
    "owner",
    "status",
    "primaryDocPath",
    "aiDocPath",
    "relatedDocPaths",
    "relatedCodePaths"
  ],
  "entryOptionalFields": [
    "tags",
    "notes",
    "reviewExpectations"
  ],
  "reviewExpectationsRequiredFieldsWhenPresent": [
    "cadence"
  ],
  "reviewExpectationsOptionalFields": [
    "lastReviewed",
    "nextReviewBy",
    "notes"
  ],
  "allowedStatusValues": [
    "draft",
    "active",
    "deprecated",
    "archived"
  ]
}
