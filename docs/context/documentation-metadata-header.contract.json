{
  "schemaVersion": "1.0.0",
  "name": "documentation-metadata-header",
  "format": {
    "type": "yaml-frontmatter",
    "openingDelimiter": "---",
    "closingDelimiter": "---",
    "placement": "The first block in the markdown file, before the H1 heading."
  },
  "requiredFields": {
    "title": {
      "type": "string",
      "description": "Human-readable document title used for navigation and retrieval labels.",
      "minimumLength": 1
    },
    "doc_type": {
      "type": "enum",
      "description": "Document role used for routing and taxonomy classification.",
      "derivedFromTaxonomyField": "document_type",
      "allowedValues": [
        "architecture-overview",
        "architecture-reference",
        "contributor-guide",
        "runbook",
        "adr",
        "baseline",
        "ai-context"
      ]
    },
    "status": {
      "type": "enum",
      "description": "Lifecycle state used to determine whether guidance is current.",
      "allowedValues": [
        "draft",
        "active",
        "deprecated",
        "superseded",
        "archived"
      ]
    },
    "authoritativeness": {
      "type": "enum",
      "description": "Authority level that signals whether this doc is source-of-truth or supporting context.",
      "allowedValues": [
        "canonical",
        "reference",
        "supplemental",
        "historical"
      ]
    },
    "owned_by": {
      "type": "string",
      "description": "Primary owning team or maintainer responsible for review and accuracy.",
      "minimumLength": 1
    },
    "last_reviewed": {
      "type": "date",
      "description": "Latest review date in ISO format.",
      "format": "YYYY-MM-DD"
    }
  },
  "optionalFields": {
    "related_code_paths": {
      "type": "array",
      "itemType": "string",
      "description": "Repo-relative paths to implementation files directly governed or explained by the document."
    },
    "supersedes": {
      "type": "string",
      "description": "Repo-relative path to an older document replaced by this document."
    },
    "superseded_by": {
      "type": "string",
      "description": "Repo-relative path to the replacement document when this document is no longer authoritative."
    }
  },
  "crossFieldRules": [
    {
      "id": "rule-supersession-mutual-exclusion",
      "description": "A document cannot set both supersedes and superseded_by."
    },
    {
      "id": "rule-superseded-status-requires-link",
      "description": "When status is superseded, superseded_by must be set."
    },
    {
      "id": "rule-last-reviewed-not-in-future",
      "description": "last_reviewed must not be later than the validation date."
    }
  ],
  "examples": {
    "architecture-overview": {
      "title": "Desktop Host Architecture Overview",
      "doc_type": "architecture-overview",
      "status": "active",
      "authoritativeness": "canonical",
      "owned_by": "team:platform-architecture",
      "last_reviewed": "2026-04-11",
      "related_code_paths": [
        "src/hosts/desktop",
        "src/composition"
      ]
    },
    "architecture-reference": {
      "title": "Workspace Domain Contracts",
      "doc_type": "architecture-reference",
      "status": "active",
      "authoritativeness": "canonical",
      "owned_by": "team:workspace-core",
      "last_reviewed": "2026-04-11",
      "related_code_paths": [
        "src/domain/workspaces",
        "src/application/workspaces"
      ]
    },
    "contributor-guide": {
      "title": "Run Submission Contributor Guide",
      "doc_type": "contributor-guide",
      "status": "active",
      "authoritativeness": "reference",
      "owned_by": "team:developer-experience",
      "last_reviewed": "2026-04-11",
      "related_code_paths": [
        "src/application/run-submission"
      ]
    },
    "runbook": {
      "title": "Secret Metadata Management Operations",
      "doc_type": "runbook",
      "status": "active",
      "authoritativeness": "canonical",
      "owned_by": "team:operations-security",
      "last_reviewed": "2026-04-11",
      "related_code_paths": [
        "src/infrastructure/secrets"
      ]
    },
    "adr": {
      "title": "ADR-003 Event Log Persistence Strategy",
      "doc_type": "adr",
      "status": "superseded",
      "authoritativeness": "historical",
      "owned_by": "team:platform-architecture",
      "last_reviewed": "2026-04-11",
      "superseded_by": "docs/adr/adr-004-event-log-storage-engine.md"
    },
    "baseline": {
      "title": "Documentation Migration Baseline",
      "doc_type": "baseline",
      "status": "archived",
      "authoritativeness": "historical",
      "owned_by": "team:developer-experience",
      "last_reviewed": "2026-04-11",
      "related_code_paths": [
        "docs/documentation-migration-baseline.inventory.json"
      ]
    },
    "ai-context": {
      "title": "Canonical Documentation Taxonomy",
      "doc_type": "ai-context",
      "status": "active",
      "authoritativeness": "canonical",
      "owned_by": "team:developer-experience",
      "last_reviewed": "2026-04-11",
      "related_code_paths": [
        "docs/context/documentation-taxonomy.contract.json"
      ]
    }
  }
}
