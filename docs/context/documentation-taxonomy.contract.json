{
  "schemaVersion": "1.0.0",
  "name": "documentation-taxonomy",
  "metadataFields": {
    "document_type": {
      "dimension": "role",
      "required": true,
      "allowedValues": [
        "architecture-overview",
        "architecture-reference",
        "contributor-guide",
        "runbook",
        "adr",
        "baseline",
        "ai-context"
      ]
    },
    "authoritativeness": {
      "dimension": "authority",
      "required": true,
      "allowedValues": [
        "canonical",
        "reference",
        "supplemental",
        "historical"
      ]
    },
    "status": {
      "dimension": "lifecycle",
      "required": true,
      "allowedValues": [
        "draft",
        "active",
        "deprecated",
        "superseded",
        "archived"
      ]
    }
  },
  "documentTypes": {
    "architecture-overview": {
      "purpose": "Explain top-level architecture boundaries, major responsibilities, and durable system shape.",
      "audience": [
        "engineers",
        "reviewers",
        "architects"
      ],
      "allowedContentScope": [
        "bounded context and layer boundaries",
        "cross-feature architecture invariants",
        "system composition maps"
      ],
      "antiPatterns": [
        "step-by-step operations procedures",
        "task-level contributor checklists",
        "feature decision history without a decision record"
      ]
    },
    "architecture-reference": {
      "purpose": "Define detailed architecture contracts for a specific subsystem or interface.",
      "audience": [
        "engineers",
        "maintainers",
        "reviewers"
      ],
      "allowedContentScope": [
        "domain/application/infrastructure contracts",
        "interface semantics and invariants",
        "extension guardrails for technical boundaries"
      ],
      "antiPatterns": [
        "runtime incident playbooks",
        "general contributor onboarding",
        "decision alternatives without ADR framing"
      ]
    },
    "contributor-guide": {
      "purpose": "Instruct contributors and AI coding agents how to implement and extend behavior safely.",
      "audience": [
        "contributors",
        "reviewers",
        "ai-assistants"
      ],
      "allowedContentScope": [
        "implementation workflows",
        "coding guardrails and checklists",
        "safe extension patterns"
      ],
      "antiPatterns": [
        "canonical runtime operations authority",
        "new architecture decisions without ADR",
        "historical snapshots as current source of truth"
      ]
    },
    "runbook": {
      "purpose": "Provide operational procedures for runtime management, diagnostics, and incident response.",
      "audience": [
        "operators",
        "on-call engineers",
        "support maintainers"
      ],
      "allowedContentScope": [
        "step-by-step operational procedures",
        "troubleshooting paths and diagnostics",
        "admin workflows and recovery steps"
      ],
      "antiPatterns": [
        "system design authority",
        "developer implementation workflow guidance",
        "decision rationale history"
      ]
    },
    "adr": {
      "purpose": "Record a specific architecture decision, alternatives, rationale, and supersession status.",
      "audience": [
        "architects",
        "engineers",
        "reviewers"
      ],
      "allowedContentScope": [
        "decision statement and context",
        "considered alternatives and tradeoffs",
        "status and supersession links"
      ],
      "antiPatterns": [
        "broad architecture references with no decision",
        "operational procedures",
        "implementation tutorial content"
      ]
    },
    "baseline": {
      "purpose": "Capture time-bound historical snapshots used for migration, auditability, and milestone traceability.",
      "audience": [
        "maintainers",
        "reviewers",
        "program leads"
      ],
      "allowedContentScope": [
        "migration inventories",
        "completion snapshots",
        "historical structure or risk baselines"
      ],
      "antiPatterns": [
        "current canonical behavior guidance",
        "active runbooks",
        "active contributor workflow authority"
      ]
    },
    "ai-context": {
      "purpose": "Provide shared context packs and taxonomy references that support human and AI reasoning across domains.",
      "audience": [
        "ai-assistants",
        "engineers",
        "maintainers"
      ],
      "allowedContentScope": [
        "cross-domain taxonomy anchors",
        "shared glossary and context mapping",
        "routing-oriented context summaries"
      ],
      "antiPatterns": [
        "operational incident procedures",
        "feature-local implementation checklists",
        "competing canonical architecture authority"
      ]
    }
  }
}
