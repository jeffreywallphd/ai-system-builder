{
  "schemaVersion": "1.0.0",
  "artifactType": "documentation-identity-and-reference-conventions",
  "description": "Stable identity and cross-artifact reference conventions for indexed documentation records.",
  "canonicalHumanSpecPath": "docs/context/documentation-identity-and-reference-conventions.md",
  "canonicalAiSpecPath": "docs/context/documentation-identity-and-reference-conventions.ai.md",
  "stableIdentity": {
    "field": "recordId",
    "format": "kebab-case-with-doc-prefix",
    "pattern": "^doc-[a-z0-9]+(?:-[a-z0-9]+)*$",
    "immutabilityRule": "recordId should remain stable after publication even if path changes."
  },
  "pathRules": {
    "pathMustStartWith": "docs/",
    "pathMustEndWith": ".md",
    "pathMustNotEndWith": ".ai.md",
    "aiPathMustEndWith": ".ai.md"
  },
  "crossArtifactReferenceFields": {
    "registryEntry": [
      "relatedRecordIds"
    ],
    "routingMapping": [
      "relatedDocRecordIds"
    ],
    "routingExample": [
      "relatedDocRecordIds"
    ],
    "contextPackCatalogEntry": [
      "relatedDocRecordIds"
    ]
  }
}

