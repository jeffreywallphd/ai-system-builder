{
  "schemaVersion": "1.0.0",
  "artifactType": "task-to-context-routing-map",
  "description": "Contract for deterministic routing between task categories and context pack identifiers.",
  "canonicalHumanSpecPath": "docs/context/routing/prompt-routing-contract.md",
  "canonicalAiSpecPath": "docs/context/routing/prompt-routing-contract.ai.md",
  "contextAssetMetadataContractPath": "docs/context/context-asset-metadata.contract.json",
  "routingRequestRequiredFields": [
    "taskSummary",
    "taskCategory",
    "requestedOutcomes",
    "changedPaths",
    "constraints"
  ],
  "routingRequestOptionalFields": [
    "primarySurfaces",
    "qualityGates",
    "exclusions",
    "notes"
  ],
  "contextAssemblyTierOrder": [
    "foundation",
    "domain",
    "implementation",
    "optional"
  ],
  "contextAssemblyProfiles": [
    {
      "id": "foundation-domain-implementation-optional-v1",
      "displayName": "Foundation, Domain, Implementation, Optional",
      "description": "Deterministic four-tier context assembly profile that maximizes high-signal context and limits optional noise.",
      "tiers": [
        {
          "tierId": "foundation",
          "priority": 1,
          "required": true,
          "tokenBudgetHint": "high",
          "selectionRule": "load canonical routing contracts and foundational pack context first.",
          "rationale": "Foundational context defines mandatory contracts and prevents downstream drift."
        },
        {
          "tierId": "domain",
          "priority": 2,
          "required": true,
          "tokenBudgetHint": "high",
          "selectionRule": "load category-mapped architecture or contributor docs for declared task scope.",
          "rationale": "Domain context narrows decision-making to the task category and changed paths."
        },
        {
          "tierId": "implementation",
          "priority": 3,
          "required": false,
          "tokenBudgetHint": "medium",
          "selectionRule": "add implementation-adjacent references only for affected surfaces and quality gates.",
          "rationale": "Implementation references are useful when execution details are needed but should remain scoped."
        },
        {
          "tierId": "optional",
          "priority": 4,
          "required": false,
          "tokenBudgetHint": "low",
          "selectionRule": "include only explicit gap-filling support material not covered by earlier tiers.",
          "rationale": "Optional context is lowest precedence to minimize token waste and context noise."
        }
      ]
    }
  ],
  "supportedTaskCategories": [
    {
      "id": "architecture-review",
      "displayName": "Architecture Review",
      "defaultSelectionMode": "ordered",
      "defaultPriorityTier": "high"
    },
    {
      "id": "feature-decomposition",
      "displayName": "Feature Decomposition",
      "defaultSelectionMode": "ordered",
      "defaultPriorityTier": "high"
    },
    {
      "id": "coding-implementation",
      "displayName": "Coding Implementation",
      "defaultSelectionMode": "ordered",
      "defaultPriorityTier": "normal"
    },
    {
      "id": "migration-refactor",
      "displayName": "Migration and Refactor",
      "defaultSelectionMode": "fallback",
      "defaultPriorityTier": "high"
    },
    {
      "id": "diagnostics",
      "displayName": "Diagnostics and Troubleshooting",
      "defaultSelectionMode": "fallback",
      "defaultPriorityTier": "high"
    },
    {
      "id": "ui-studio",
      "displayName": "UI and Studio Experience",
      "defaultSelectionMode": "ordered",
      "defaultPriorityTier": "normal"
    },
    {
      "id": "runtime-security",
      "displayName": "Runtime and Security",
      "defaultSelectionMode": "ordered",
      "defaultPriorityTier": "critical"
    },
    {
      "id": "documentation-change",
      "displayName": "Documentation Change",
      "defaultSelectionMode": "single",
      "defaultPriorityTier": "normal"
    }
  ],
  "mappingRequiredFields": [
    "taskId",
    "taskCategory",
    "intent",
    "routingInputs",
    "contextAssemblyProfileId",
    "contextAssemblyTierHints",
    "packIds",
    "selectionMode",
    "priorityTier",
    "status",
    "id",
    "title",
    "purpose",
    "domain",
    "owner",
    "relatedDocPaths",
    "relatedCodePaths",
    "relatedDocRecordIds"
  ],
  "mappingOptionalFields": [
    "excludePackIds",
    "fallbackPackIds",
    "notes",
    "reviewExpectations"
  ],
  "reviewExpectationsRequiredFieldsWhenPresent": [
    "cadence"
  ],
  "reviewExpectationsOptionalFields": [
    "lastReviewed",
    "nextReviewBy",
    "notes"
  ],
  "allowedSelectionModes": [
    "ordered",
    "fallback",
    "single"
  ],
  "priorityTiers": [
    "critical",
    "high",
    "normal",
    "low"
  ],
  "fallbackPolicy": {
    "allowFallbackPackIds": true,
    "fallbackTriggerRules": [
      "all_primary_pack_ids_missing_or_inactive",
      "task_constraints_exclude_all_primary_pack_ids",
      "task_category_mismatch_requires_safe_default"
    ],
    "defaultFallbackBehavior": "use_category_default_then_global_defaults"
  },
  "selectionRules": [
    "include active packs matching task category and routing inputs.",
    "apply pack priority in ascending order; lower numbers are higher precedence.",
    "apply exclusion rules before fallback evaluation.",
    "preserve deterministic pack ordering in final routing result."
  ],
  "exclusionRules": [
    "exclude packs marked deprecated unless explicitly requested.",
    "exclude packs whose declared scope does not match changedPaths.",
    "exclude packs explicitly listed in mapping.excludePackIds.",
    "exclude baseline or historical docs by default unless routingInputs or requestedOutcomes explicitly require historical evidence.",
    "exclude superseded pointer docs by default unless the task explicitly targets supersession or redirect maintenance."
  ],
  "allowedStatusValues": [
    "draft",
    "active",
    "deprecated"
  ]
}
