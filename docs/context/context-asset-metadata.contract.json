{
  "schemaVersion": "1.0.0",
  "artifactType": "context-asset-metadata-standard",
  "description": "Lightweight metadata standard for context pack catalog entries and task-to-context routing records.",
  "canonicalHumanSpecPath": "docs/context/context-asset-metadata.md",
  "canonicalAiSpecPath": "docs/context/context-asset-metadata.ai.md",
  "requiredFields": [
    "id",
    "title",
    "purpose",
    "domain",
    "owner",
    "status",
    "relatedDocPaths",
    "relatedCodePaths"
  ],
  "optionalFields": [
    "tags",
    "notes",
    "reviewExpectations"
  ],
  "reviewExpectations": {
    "requiredFieldsWhenPresent": [
      "cadence"
    ],
    "optionalFields": [
      "lastReviewed",
      "nextReviewBy",
      "notes"
    ],
    "allowedCadenceValues": [
      "on-contract-change",
      "per-story",
      "per-epic-milestone",
      "quarterly"
    ]
  },
  "assetTypeRequirements": {
    "context-pack-catalog-entry": {
      "requiredFields": [
        "id",
        "title",
        "purpose",
        "domain",
        "owner",
        "status",
        "relatedDocPaths",
        "relatedCodePaths"
      ],
      "optionalFields": [
        "tags",
        "notes",
        "reviewExpectations"
      ]
    },
    "task-to-context-routing-mapping": {
      "requiredFields": [
        "id",
        "title",
        "purpose",
        "domain",
        "owner",
        "status",
        "relatedDocPaths",
        "relatedCodePaths"
      ],
      "optionalFields": [
        "notes",
        "reviewExpectations"
      ]
    }
  },
  "crossFieldRules": [
    {
      "id": "metadata-id-stable-after-publication",
      "description": "The id field must remain stable once an entry is published."
    },
    {
      "id": "metadata-status-must-use-parent-contract-enum",
      "description": "The status field must use allowed values from the containing asset contract."
    },
    {
      "id": "metadata-review-expectations-requires-cadence",
      "description": "If reviewExpectations exists, cadence is required."
    }
  ]
}
