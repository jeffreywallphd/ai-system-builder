{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "incremental": false
  },
  "include": [
    "../../modules/**/*.ts",
    "../../modules/**/*.tsx",
    "../../modules/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/tests/**"
  ]
}
