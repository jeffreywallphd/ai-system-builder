# Client/runtime defaults (safe example values)
NODE_ENV=development
VITE_APP_NAME=ai-loom-studio
VITE_COMFYUI_BASE_URL=http://localhost:8188
VITE_HUGGINGFACE_API_BASE_URL=https://huggingface.co/api
PYTHON_RUNTIME_MODE=managed-local
PYTHON_RUNTIME_BASE_URL=http://localhost:8100
MCP_RUNTIME_ENABLED=true
# Identity provider/account policy controls
# IDENTITY_LOCAL_PROVIDER_ENABLED=true
# IDENTITY_LOCAL_PROVIDER_ID=provider:local-password
# IDENTITY_LOCAL_PROVIDER_DISPLAY_NAME=Local Password
# IDENTITY_LOCAL_CREDENTIAL_POLICY_ID=policy:local-password
# IDENTITY_BOOTSTRAP_SEED_DEFAULTS=true
# IDENTITY_ACCOUNT_ALLOW_LOCAL_REGISTRATION=true
# IDENTITY_ACCOUNT_ALLOW_ADMINISTRATION=true
# IDENTITY_LOCAL_CREDENTIAL_MIN_LENGTH=12
# IDENTITY_LOCAL_CREDENTIAL_MAX_LENGTH=128
# IDENTITY_LOCAL_CREDENTIAL_REQUIRE_LOWERCASE=true
# IDENTITY_LOCAL_CREDENTIAL_REQUIRE_UPPERCASE=true
# IDENTITY_LOCAL_CREDENTIAL_REQUIRE_NUMBER=true
# IDENTITY_LOCAL_CREDENTIAL_REQUIRE_SYMBOL=true
# IDENTITY_LOCAL_CREDENTIAL_MIN_UNIQUE_CHARACTERS=6
# IDENTITY_LOCAL_CREDENTIAL_MAX_REPEATED_CHARACTERS=3
# IDENTITY_LOCAL_CREDENTIAL_BLOCKED_SUBSTRINGS=
# IDENTITY_LOCAL_CREDENTIAL_MIN_PASSWORD_AGE_DAYS=0
# IDENTITY_LOCAL_CREDENTIAL_MAX_PASSWORD_AGE_DAYS=365
# IDENTITY_LOCAL_CREDENTIAL_PASSWORD_HISTORY_COUNT=10
# IDENTITY_LOCAL_CREDENTIAL_MAX_FAILED_ATTEMPTS=5
# IDENTITY_LOCAL_CREDENTIAL_LOCKOUT_DURATION_MINUTES=15
# Identity session policy controls (minutes)
# IDENTITY_SESSION_DESKTOP_TTL_MINUTES=43200
# IDENTITY_SESSION_DESKTOP_ALLOW_REFRESH=false
# IDENTITY_SESSION_DESKTOP_INACTIVITY_TIMEOUT_MINUTES=
# IDENTITY_SESSION_THIN_CLIENT_TTL_MINUTES=720
# IDENTITY_SESSION_THIN_CLIENT_ALLOW_REFRESH=true
# IDENTITY_SESSION_THIN_CLIENT_INACTIVITY_TIMEOUT_MINUTES=
# IDENTITY_SESSION_DESKTOP_TRUST_REQUIREMENT=allow-pairing
# IDENTITY_SESSION_THIN_CLIENT_TRUST_REQUIREMENT=allow-untrusted
# Optional for LAN/browser access from another device
# SERVICE_SUPERVISOR_HOST=0.0.0.0
# PYTHON_RUNTIME_BIND_HOST=0.0.0.0

# Optional token: keep blank locally unless needed for authenticated requests
# HUGGINGFACE_API_TOKEN=

# Optional dev sync overrides (set locally; do not edit source files for machine-specific values)
# VITE_DEV_SYNC_BASE_URL=http://192.168.1.100:8787
# VITE_DEV_SYNC_TOKEN=ai-loom-dev-sync
# VITE_MODEL_INSTALL_DIRECTORY=dev/models
# VITE_IDENTITY_API_BASE_URL=http://127.0.0.1:8788
# AI_LOOM_BROWSER_IDENTITY_HOST=127.0.0.1
# AI_LOOM_BROWSER_IDENTITY_PORT=8788

# Optional internal CA protected secret store settings
# AI_LOOM_INTERNAL_CA_PROTECTED_SECRETS_DIRECTORY=./runtime-assets/internal-ca-secrets
# AI_LOOM_INTERNAL_CA_PROTECTED_SECRETS_KEY=<32-byte key encoded as base64 or 64-char hex>
# AI_LOOM_INTERNAL_CA_PROTECTED_SECRETS_KEYS_BY_SCOPE=default:<base64key>,ca-signing:<base64key>

# Optional secure transport host wiring controls
# AI_LOOM_TRANSPORT_TRUST_ENFORCEMENT=true
# AI_LOOM_TRANSPORT_ALLOW_INSECURE_LOOPBACK=true
# AI_LOOM_INTERNAL_CA_SERVER_MANAGED_TLS_ENABLED=false
# AI_LOOM_INTERNAL_CA_SERVER_REFERENCE_ID=server:authoritative
# AI_LOOM_INTERNAL_CA_SERVER_TLS_PRIVATE_KEY_MATERIAL_REF=
