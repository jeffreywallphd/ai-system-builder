# Client/runtime defaults (safe example values)
NODE_ENV=development
VITE_APP_NAME=ai-loom-studio
VITE_COMFYUI_BASE_URL=http://localhost:8188
VITE_HUGGINGFACE_API_BASE_URL=https://huggingface.co/api
PYTHON_RUNTIME_MODE=local-http
PYTHON_RUNTIME_BASE_URL=http://localhost:8100
MCP_RUNTIME_ENABLED=true

# Optional token: keep blank locally unless needed for authenticated requests
# HUGGINGFACE_API_TOKEN=

# Optional dev sync overrides (set locally; do not edit source files for machine-specific values)
# VITE_DEV_SYNC_BASE_URL=http://192.168.1.100:8787
# VITE_DEV_SYNC_TOKEN=ai-loom-dev-sync
# VITE_MODEL_INSTALL_DIRECTORY=dev/models
