{
  "id": "basic-rag-pipeline",
  "metadata": {
    "name": "Basic RAG Pipeline",
    "description": "Load documents, save them to a knowledge base, retrieve context, and draft a response.",
    "author": "OpenAI Codex",
    "tags": [
      "rag",
      "langchain",
      "knowledge-base"
    ],
    "version": "1.0.0"
  },
  "status": "draft",
  "isEnabled": true,
  "executionPolicy": "acyclic-only",
  "nodes": [
    {
      "id": "rag-loader",
      "definitionId": "langchain.document_loader",
      "title": "Document Loader",
      "position": {
        "x": 60,
        "y": 60
      },
      "properties": [
        {
          "id": "type",
          "value": "text"
        },
        {
          "id": "encoding",
          "value": "utf-8"
        }
      ],
      "isEnabled": true,
      "isCollapsed": false
    },
    {
      "id": "rag-chunker",
      "definitionId": "langchain.document_to_chunks",
      "title": "Chunker",
      "position": {
        "x": 520,
        "y": 60
      },
      "properties": [
        {
          "id": "chunkSize",
          "value": 300
        },
        {
          "id": "chunkOverlap",
          "value": 50
        },
        {
          "id": "preserveMetadata",
          "value": true
        }
      ],
      "isEnabled": true,
      "isCollapsed": false
    },
    {
      "id": "rag-embeddings",
      "definitionId": "langchain.embeddings",
      "title": "Embeddings",
      "position": {
        "x": 980,
        "y": 60
      },
      "properties": [
        {
          "id": "normalize",
          "value": true
        }
      ],
      "isEnabled": true,
      "isCollapsed": false
    },
    {
      "id": "rag-upsert",
      "definitionId": "langchain.vector_store_upsert",
      "title": "Vector Store Upsert",
      "position": {
        "x": 1440,
        "y": 60
      },
      "properties": [
        {
          "id": "storeType",
          "value": "memory"
        },
        {
          "id": "collectionName",
          "value": "basic-rag"
        }
      ],
      "isEnabled": true,
      "isCollapsed": false
    },
    {
      "id": "rag-search",
      "definitionId": "langchain.similarity_search",
      "title": "Similarity Search",
      "position": {
        "x": 1900,
        "y": 60
      },
      "properties": [
        {
          "id": "k",
          "value": 4
        },
        {
          "id": "scoreThreshold",
          "value": 0
        }
      ],
      "isEnabled": true,
      "isCollapsed": false
    },
    {
      "id": "rag-context",
      "definitionId": "langchain.context_formatter",
      "title": "Context Formatter",
      "position": {
        "x": 2360,
        "y": 60
      },
      "properties": [
        {
          "id": "template",
          "value": "[{index}] {content}"
        },
        {
          "id": "maxLength",
          "value": 2000
        }
      ],
      "isEnabled": true,
      "isCollapsed": false
    },
    {
      "id": "rag-llm",
      "definitionId": "langchain.llm_chat",
      "title": "LLM",
      "position": {
        "x": 2820,
        "y": 60
      },
      "properties": [
        {
          "id": "model",
          "value": "demo-rag-model"
        },
        {
          "id": "temperature",
          "value": 0.2
        }
      ],
      "isEnabled": true,
      "isCollapsed": false
    }
  ],
  "connections": [
    {
      "id": "rag-loader-to-chunker",
      "source": {
        "nodeId": "rag-loader",
        "portId": "documents"
      },
      "target": {
        "nodeId": "rag-chunker",
        "portId": "documents"
      },
      "kind": "data",
      "state": "active",
      "isEnabled": true
    },
    {
      "id": "rag-chunker-to-embeddings",
      "source": {
        "nodeId": "rag-chunker",
        "portId": "chunks"
      },
      "target": {
        "nodeId": "rag-embeddings",
        "portId": "texts"
      },
      "kind": "data",
      "state": "active",
      "isEnabled": true
    },
    {
      "id": "rag-loader-to-upsert",
      "source": {
        "nodeId": "rag-loader",
        "portId": "documents"
      },
      "target": {
        "nodeId": "rag-upsert",
        "portId": "documents"
      },
      "kind": "data",
      "state": "active",
      "isEnabled": true
    },
    {
      "id": "rag-embeddings-to-upsert",
      "source": {
        "nodeId": "rag-embeddings",
        "portId": "embeddings"
      },
      "target": {
        "nodeId": "rag-upsert",
        "portId": "embeddings"
      },
      "kind": "data",
      "state": "active",
      "isEnabled": true
    },
    {
      "id": "rag-upsert-to-search",
      "source": {
        "nodeId": "rag-upsert",
        "portId": "vectorStore"
      },
      "target": {
        "nodeId": "rag-search",
        "portId": "vectorStore"
      },
      "kind": "data",
      "state": "active",
      "isEnabled": true
    },
    {
      "id": "rag-search-to-context",
      "source": {
        "nodeId": "rag-search",
        "portId": "documents"
      },
      "target": {
        "nodeId": "rag-context",
        "portId": "documents"
      },
      "kind": "data",
      "state": "active",
      "isEnabled": true
    },
    {
      "id": "rag-context-to-llm",
      "source": {
        "nodeId": "rag-context",
        "portId": "context"
      },
      "target": {
        "nodeId": "rag-llm",
        "portId": "prompt"
      },
      "kind": "data",
      "state": "active",
      "isEnabled": true
    }
  ]
}
