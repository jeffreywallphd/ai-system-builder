# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

#python env
.venv/
venv/
python-runtime/.venv/

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

#node package lock
package-lock.json

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
.env
.env.*
!.env.example

# Secrets and local credentials
*.pem
*.key
*.p12
*.cer
*.crt
*.jks
*.kdbx
secrets/
!src/infrastructure/security/secrets/
!src/infrastructure/security/secrets/**

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next
out

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
# Comment in the public line in if your project uses Gatsby and not Next.js
# https://nextjs.org/blog/next-9-1#public-directory-support
# public

# vuepress build output
.vuepress/dist

# vuepress v2.x temp and cache directory
.temp
.cache

# Sveltekit cache directory
.svelte-kit/

# vitepress build output
**/.vitepress/dist

# vitepress cache directory
**/.vitepress/cache

# Docusaurus cache and generated files
.docusaurus

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# Firebase cache directory
.firebase/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# yarn v3
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Vite logs files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Local workflow user data
/dev/workflow-data/workflows/*
!/dev/workflow-data/workflows/.gitkeep
!/dev/workflow-data/workflows/sample-image-pipeline.json
!/dev/workflow-data/workflows/sample-text-analysis.json
/dev/workflow-data/inputs/*
!/dev/workflow-data/inputs/.gitkeep
/dev/workflow-data/outputs/*
!/dev/workflow-data/outputs/.gitkeep

# Local per-user workflow data
/user/workflow-data/workflows/*
!/user/workflow-data/workflows/.gitkeep
/user/workflow-data/inputs/*
!/user/workflow-data/inputs/.gitkeep
/user/workflow-data/outputs/*
!/user/workflow-data/outputs/.gitkeep
/user/workflow-data/mcp/
/user/*/workflow-data/workflows/*
!/user/*/workflow-data/workflows/.gitkeep
/user/*/workflow-data/inputs/*
!/user/*/workflow-data/inputs/.gitkeep
/user/*/workflow-data/outputs/*
!/user/*/workflow-data/outputs/.gitkeep
/user/*/workflow-data/mcp/

# Managed Python runtime artifacts (local machine only)
/python-runtime/.venv.managed/
/python-runtime/.ai-loom-runtime/
/python-runtime/.ai-loom-python-runtime-state.json
/python-runtime/**/__pycache__/

# Local workflow runtime indexes and sqlite sidecars
/dev/workflow-data/workflows/*.sqlite
/dev/workflow-data/workflows/*.sqlite-shm
/dev/workflow-data/workflows/*.sqlite-wal
/dev/workflow-data/workflows/*.sqlite-journal

# Local model payloads (keep placeholders/docs)
/dev/model-files/*
!/dev/model-files/.gitkeep
!/dev/model-files/README.md

# Private packaged Python runtimes (keep templates/docs)
/runtime-assets/python/*/
!/runtime-assets/python/README.md
!/runtime-assets/python/manifest.template.json
