{
  "name": "ai-system-builder",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "main": ".webpack/main",
  "workspaces": [
    "apps/server",
    "apps/thin-client"
  ],
  "config": {
    "forge": "./apps/desktop/forge.config.js"
  },
  "scripts": {
    "dev": "npm run dev:desktop",
    "dev:desktop": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "start": "npm run dev:desktop",
    "test": "node --preserve-symlinks --preserve-symlinks-main dev-tools/scripts/testing/run-non-browser-tests.mjs",
    "test:non-browser": "node --preserve-symlinks --preserve-symlinks-main dev-tools/scripts/testing/run-non-browser-tests.mjs",
    "test:postgres-live": "node --import tsx --test modules/adapters/persistence/postgres/tests/postgres-database.live.integration.test.ts",
    "test:postgres-recovery": "node --import tsx dev-tools/scripts/persistence/postgres-recovery-drill.ts",
    "docs:check": "node --preserve-symlinks --preserve-symlinks-main dev-tools/scripts/docs/check-doc-drift.mjs",
    "architecture:check": "node --preserve-symlinks --preserve-symlinks-main dev-tools/scripts/architecture/check-module-dependencies.mjs",
    "agent-support:check": "node --preserve-symlinks --preserve-symlinks-main dev-tools/scripts/agent-support/check-agent-support.mjs",
    "security:dependencies": "node dev-tools/scripts/security/check-dependency-security.mjs",
    "deployment:check": "node --preserve-symlinks --preserve-symlinks-main dev-tools/scripts/deployment/check-server-deployment-artifacts.mjs",
    "deployment:smoke": "node --preserve-symlinks --preserve-symlinks-main dev-tools/scripts/deployment/smoke-managed-server.mjs",
    "dev:thin-client": "npm run dev -w @ai-system-builder/thin-client",
    "dev:secure-thin-client": "node --preserve-symlinks --preserve-symlinks-main dev-tools/scripts/thin-client/dev-secure-thin-client.mjs",
    "build:thin-client": "npm run build -w @ai-system-builder/thin-client",
    "preview:thin-client": "npm run preview -w @ai-system-builder/thin-client",
    "dev:server": "npm run dev -w @ai-system-builder/server",
    "build:server": "npm run build -w @ai-system-builder/server",
    "start:server": "npm run start -w @ai-system-builder/server",
    "persistence:sqlite": "node --preserve-symlinks --preserve-symlinks-main dev-tools/scripts/persistence/run-sqlite-maintenance.mjs",
    "persistence:postgres": "node --import tsx dev-tools/scripts/persistence/postgres-maintenance.ts",
    "tenancy:postgres": "node --import tsx dev-tools/scripts/tenancy/postgres-tenancy-admin.ts"
  },
  "dependencies": {
    "@huggingface/hub": "^2.11.0",
    "busboy": "^1.6.0",
    "express": "^5.1.0",
    "jose": "6.2.3",
    "pg": "^8.22.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "selfsigned": "5.5.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-webpack": "^7.10.2",
    "@types/busboy": "^1.5.4",
    "@types/node": "^24.7.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vercel/webpack-asset-relocator-loader": "^1.10.0",
    "css-loader": "^7.1.2",
    "electron": "41.10.2",
    "jsdom": "^26.1.0",
    "node-loader": "^2.1.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "webpack": "^5.99.9"
  },
  "overrides": {
    "tar": "7.5.20",
    "tmp": "0.2.7",
    "webpack-dev-server": "5.2.6",
    "sockjs": {
      "uuid": "11.1.1"
    }
  }
}
