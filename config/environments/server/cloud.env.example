NODE_ENV=production
DEPLOYMENT_SHAPE=cloud
PORT=3010
AI_SYSTEM_BUILDER_SECURITY_MODE=oidc-bearer
AI_SYSTEM_BUILDER_OIDC_ISSUER=https://identity.cloud.example
AI_SYSTEM_BUILDER_OIDC_AUDIENCE=ai-system-builder
AI_SYSTEM_BUILDER_OIDC_JWKS_URI=https://identity.cloud.example/.well-known/jwks.json
AI_SYSTEM_BUILDER_TENANT_PLACEMENT_MODE=pooled
AI_SYSTEM_BUILDER_TLS_CERT_MODE=manual
AI_SYSTEM_BUILDER_TLS_CERT_PATH=/run/secrets/tls.crt
AI_SYSTEM_BUILDER_TLS_KEY_PATH=/run/secrets/tls.key
POSTGRES_SSL_MODE=verify-full
POSTGRES_POOL_MAX=10
POSTGRES_CONNECTION_TIMEOUT_MS=5000
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_STATEMENT_TIMEOUT_MS=30000
SERVER_STORAGE_ROOT=/var/lib/ai-system-builder/artifacts
SERVER_RUNTIME_ROOT=/var/lib/ai-system-builder/runtime
# Premium dedicated placement instead sets AI_SYSTEM_BUILDER_TENANT_PLACEMENT_MODE=dedicated
# and AI_SYSTEM_BUILDER_DEDICATED_ORGANIZATION_ID=<provisioned-id>.
# Inject DATABASE_URL and POSTGRES_SSL_CA_PEM through the cloud secret manager.
